# Wireless HeatMapper - variables de produccion para VM Azure.
# Copiar como /opt/wireless-heatmapper/.env y completar en el servidor.

GHCR_OWNER=borysinho
IMAGE_TAG=latest

POSTGRES_DB=heatmapper
POSTGRES_USER=heatmapper_user
POSTGRES_PASSWORD=cambiar_en_azure_vm

SECRET_KEY=cambiar_por_un_secreto_largo_y_unico
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=false

# JSON de lista. En Azure usar el dominio gratuito con HTTPS.
CORS_ORIGINS=["https://wireless-heatmapper-g24.eastus2.cloudapp.azure.com"]

STORAGE_ROOT=/var/lib/heatmapper/planos
STORAGE_URL_SECRET=cambiar_por_otro_secreto_largo_y_unico
STORAGE_URL_TTL_SECONDS=3600

# Dejar vacio para que el backend devuelva rutas relativas bajo /api.
PUBLIC_API_URL=

EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=correo@gmail.com
SMTP_PASSWORD=contraseña_de_aplicacion
SMTP_FROM_EMAIL=correo@gmail.com
SMTP_FROM_NAME=Wireless HeatMapper
PUBLIC_WEB_URL=https://wireless-heatmapper-g24.eastus2.cloudapp.azure.com

# Azure OpenAI. Obligatorio para que el chatbot publico use IA real.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_POLIGONO_DEPLOYMENT=whm-poligono-gpt5-nano
AZURE_OPENAI_POLIGONO_MAX_PX=768
AZURE_OPENAI_POLIGONO_TIMEOUT_SECONDS=30
AZURE_OPENAI_CHATBOT_DEPLOYMENT=
AZURE_OPENAI_CHATBOT_TIMEOUT_SECONDS=20

# Manual publicado por el reverse proxy productivo.
VITE_MANUAL_USUARIO_URL=https://wireless-heatmapper-g24.eastus2.cloudapp.azure.com/manual/

FIREBASE_PROJECT_ID=
