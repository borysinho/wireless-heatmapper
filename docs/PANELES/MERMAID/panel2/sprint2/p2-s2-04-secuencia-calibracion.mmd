sequenceDiagram
  actor TEC as Tecnico
  participant APP as PlanoEditorPage
  participant CUBIT as PlanosCubit
  participant BACKEND as Backend /planos/{id}/calibracion
  participant DB as PostgreSQL

  TEC->>APP: tocar dos puntos
  APP-->>TEC: solicitar distancia real
  TEC->>APP: ingresar metros
  APP->>CUBIT: confirmar calibración
  CUBIT->>BACKEND: PATCH calibracion
  BACKEND->>DB: actualizar escala y puntos referencia
  DB-->>BACKEND: calibración persistida
  BACKEND-->>CUBIT: plano calibrado
  CUBIT-->>APP: estado exitoso
  APP-->>TEC: mostrar factor y regla
