@startuml
title Modelo de Contexto - Wireless HeatMapper
left to right direction
skinparam packageStyle rectangle
skinparam actorBackgroundColor #EBF5FB
skinparam actorBorderColor #2980B9
skinparam usecaseBackgroundColor #FDFEFE
skinparam usecaseBorderColor #2980B9
skinparam rectangleBackgroundColor #FAFAFA
skinparam rectangleBorderColor #BDC3C7
skinparam arrowColor #5D6D7E
skinparam noteBackgroundColor #FFFDE7

actor "Tecnico de campo" as Tecnico
actor "Administrador" as Admin
actor "Cliente" as Cliente
actor "Android WifiManager API" as Wifi
actor "Servicio IA backend" as IA

rectangle "Wireless HeatMapper" {
  usecase "UC01\nGestionar proyecto" as UC01
  usecase "UC02\nImportar plano" as UC02
  usecase "UC03\nCalibrar plano" as UC03
  usecase "UC04\nMarcar punto" as UC04
  usecase "UC05\nCapturar senales WiFi" as UC05
  usecase "UC06\nGenerar mapa de calor" as UC06
  usecase "UC08\nGenerar propuesta IA" as UC08
  usecase "UC09\nComparar propuesta" as UC09
  usecase "UC11\nAutenticar usuario" as UC11
  usecase "UC13\nGestionar usuarios" as UC13
  usecase "UC15\nGenerar enlace cliente" as UC15
  usecase "UC16\nConsultar heatmap" as UC16
  usecase "UC17\nVer conjuntos AP" as UC17
  usecase "UC18\nVer proyectos organizacion" as UC18
  usecase "UC19\nGestionar clientes" as UC19
}

Tecnico --> UC11
Tecnico --> UC01
Tecnico --> UC02
Tecnico --> UC03
Tecnico --> UC04
Tecnico --> UC05
Tecnico --> UC06

Admin --> UC11
Admin --> UC13
Admin --> UC18
Admin --> UC19
Admin --> UC08
Admin --> UC09
Admin --> UC15

Cliente --> UC16
Cliente --> UC17

UC05 -- Wifi
UC08 -- IA
UC04 ..> UC05 : <<include>>
UC06 ..> UC05 : <<requires>>
UC09 ..> UC08 : <<extend>>
UC15 ..> UC16 : <<include>>
UC16 ..> UC17 : <<include>>

note bottom of UC05
  La captura se envia al backend.
  No existe base de datos local de dominio.
end note
@enduml

