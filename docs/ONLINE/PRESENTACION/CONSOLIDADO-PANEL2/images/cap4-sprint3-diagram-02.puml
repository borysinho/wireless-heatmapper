@startuml
title PB-03 — Captura WiFi en línea (modo puntual, sin almacenamiento local)
skinparam sequenceArrowColor #2980B9
skinparam sequenceBoxBackgroundColor #EBF5FB
skinparam noteBackgroundColor #FFFDE7

actor "Técnico" as T
participant "CapturaPage\n(Flutter)" as UI
participant "CapturaCubit\n(BLoC)" as Cubit
participant "WifiScanner" as WS
participant "ThrottlingManager" as TM
participant "CapturaDioClient" as DC
participant "Backend\nFastAPI" as API
database "PostgreSQL" as DB

T -> UI: tap en plano\n(posición x,y en píxeles)
UI -> Cubit: marcarPuntoEnPlano(x, y, planoId)
Cubit -> API: POST /api/planos/{id}/puntos\n{xPx, yPx}
API --> Cubit: 201 {puntoId, xM, yM}
Cubit -> UI: estado PuntoCreado

loop Ciclo de scan (respeta throttling)
  Cubit -> TM: solicitarScan()
  alt Throttling activo
    TM --> Cubit: esperar Xs
    Cubit -> UI: CapturaEsperando(segundosRestantes)
  else
    TM -> WS: startSingleScan()
    WS --> TM: lista AccessPoint[]\n(SSID, BSSID, RSSI, canal, frec)
    TM --> Cubit: resultadoScan
  end
  Cubit -> DC: enviarMediciones(puntoId, loteAP, numeroLectura)
  DC -> API: POST /api/puntos/{id}/mediciones\n[{ssid,bssid,rssiDbm,canal,frecMhz,\n  numeroLectura}]
  alt Éxito
    API -> DB: INSERT medicion_wifi (n filas)
    API --> DC: 201 {medicionesRegistradas: n}
    DC --> Cubit: éxito
    Cubit -> UI: MedicionRegistrada(rssiPromedio)
  else Fallo de red (3 reintentos agotados)
    DC --> Cubit: errorConexion
    Cubit -> UI: ErrorCaptura(mensaje)
    note right: SIN persistencia local\nSnackBar "Sin conexión.\nMedición no registrada."
  end
end
@enduml
