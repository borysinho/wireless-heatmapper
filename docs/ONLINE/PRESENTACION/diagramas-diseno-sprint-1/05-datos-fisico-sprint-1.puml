@startuml
title Diseño de Datos — Diseño Físico (Tablas PostgreSQL 15)\nSprint 1 — Wireless HeatMapper\nMigraciones: 0001_initial · 0002_cliente_y_proyecto
skinparam classBackgroundColor #EBF5FB
skinparam classBorderColor #2980B9
skinparam classHeaderBackgroundColor #2980B9
skinparam classHeaderFontColor white
skinparam arrowColor #2980B9
skinparam noteBackgroundColor #FFFDE7
hide circle

' ─── Migración 0001: usuario + refresh_token ─────────────────

class "usuario" <<PostgreSQL table>> {
  id               SERIAL          NOT NULL  «PK»
  --
  nombre           VARCHAR(120)    NOT NULL
  email            VARCHAR(255)    NOT NULL  «UNIQUE» «INDEX»
  password_hash    VARCHAR(255)    NOT NULL
  rol              VARCHAR(30)     NOT NULL  DEFAULT 'tecnico'
  activo           BOOLEAN         NOT NULL  DEFAULT TRUE
  ultimo_acceso    TIMESTAMPTZ     NULL
  created_at       TIMESTAMPTZ     NOT NULL  DEFAULT now()
  --
  «CHECK» rol IN ('tecnico','admin')
}

class "refresh_token" <<PostgreSQL table>> {
  id               SERIAL          NOT NULL  «PK»
  --
  token            VARCHAR(64)     NOT NULL  «UNIQUE»
  expires_at       TIMESTAMPTZ     NOT NULL
  created_at       TIMESTAMPTZ     NOT NULL  DEFAULT now()
  usuario_id       INTEGER         NOT NULL  «FK» «INDEX»
  --
  «FK» usuario_id → usuario(id) ON DELETE CASCADE
}

' ─── Migración 0002: cliente + proyecto + ENUM ───────────────

class "estado_proyecto" <<PostgreSQL ENUM>> {
  'nuevo'
  'en_progreso'
  'completado'
  'archivado'
}

class "cliente" <<PostgreSQL table>> {
  id               SERIAL          NOT NULL  «PK»
  --
  nombre           VARCHAR(100)    NOT NULL  «UNIQUE»
  activo           BOOLEAN         NOT NULL  DEFAULT TRUE
  created_at       TIMESTAMPTZ     NOT NULL  DEFAULT now()
}

class "proyecto" <<PostgreSQL table>> {
  id               SERIAL          NOT NULL  «PK»
  --
  nombre           VARCHAR(200)    NOT NULL
  descripcion      VARCHAR(500)    NULL
  estado           estado_proyecto NOT NULL  DEFAULT 'nuevo'
  ultima_actividad TIMESTAMPTZ     NOT NULL  DEFAULT now()
  cantidad_puntos  INTEGER         NOT NULL  DEFAULT 0
  created_at       TIMESTAMPTZ     NOT NULL  DEFAULT now()
  tecnico_id       INTEGER         NOT NULL  «FK» «INDEX»
  cliente_id       INTEGER         NULL      «FK» «INDEX»
  --
  «FK» tecnico_id → usuario(id)
  «FK» cliente_id → cliente(id)
}

' ─── Relaciones FK ───────────────────────────────────────────
"usuario" "1" -right-> "0..*" "refresh_token" : FK usuario_id\nON DELETE CASCADE
"usuario" "1" -down-> "0..*" "proyecto" : FK tecnico_id
"cliente" "1" -down-> "0..*" "proyecto" : FK cliente_id (NULLABLE)
"proyecto" -right-> "estado_proyecto" : tipo ENUM

' ─── Índices definidos ───────────────────────────────────────
note bottom of "usuario"
