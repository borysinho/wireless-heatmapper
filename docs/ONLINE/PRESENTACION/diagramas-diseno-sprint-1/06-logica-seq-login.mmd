%% PB-09: Autenticar Usuario (Login y Refresh Token)
%% Wireless HeatMapper — modalidad 100% en línea
%% Compatibilidad StarUML: solo ->> y -->>, sin box/rect/link/estilos

sequenceDiagram
    actor user as Técnico
    participant splash as SplashPage
    participant login as LoginPage
    participant cubit as AuthCubit
    participant ds as AuthRemoteDS
    participant nginx as Nginx
    participant be_login as API auth-login
    participant be_refresh as API auth-refresh
    participant db as PostgreSQL
    participant ss as SecureStorage

    %% Arranque de la app: verificación de sesión previa
    splash->>ss: leer access_token + refresh_token
    alt tokens presentes
        splash->>ds: POST /api/auth/refresh
        ds->>nginx: HTTPS
        nginx->>be_refresh: proxy_pass
        be_refresh->>db: SELECT refresh_token WHERE expires_at > now()
        db-->>be_refresh: registro encontrado
        be_refresh-->>splash: 200 nuevo access_token
        splash->>ss: guardar nuevo access_token
        splash->>user: navegar a ProyectosPage
    else no hay tokens o refresh expirado
        splash->>user: navegar a LoginPage
    end

    %% Login con credenciales
    user->>login: ingresa email + contraseña
    login->>cubit: AuthCubit.login(email, password)
    cubit->>ds: POST /api/auth/login
    ds->>nginx: HTTPS :443
    nginx->>be_login: proxy_pass :8000
    be_login->>db: SELECT usuario WHERE email = :email
    db-->>be_login: fila usuario (o vacío)

    opt CA-1: credenciales válidas y cuenta activa
        be_login->>be_login: bcrypt.checkpw(password, hash)
        be_login->>be_login: generar access_token + refresh_token
        be_login->>db: INSERT INTO refresh_token
        be_login->>db: UPDATE usuario SET ultimo_acceso = now()
        be_login-->>ds: 200 access_token + refresh_token + usuario
        ds-->>cubit: TokenResponse
        cubit->>ss: guardar tokens cifrado AES
        cubit-->>login: AuthState.authenticated
        login->>user: navegar a ProyectosPage
    end

    opt CA-2: credenciales inválidas
        be_login-->>ds: 401 Credenciales inválidas
        ds-->>cubit: DioException 401
        cubit-->>login: AuthState.error
        login->>user: mostrar mensaje de error
    end

    opt CA-3: cuenta desactivada
        be_login-->>ds: 403 Cuenta desactivada
        ds-->>cubit: DioException 403
        cubit-->>login: AuthState.error cuenta desactivada
        login->>user: mostrar mensaje específico
    end

    opt CA-5: sin conexión al backend
        ds-->>cubit: DioException ConnectionError
        cubit-->>login: AuthState.sinConexion
        login->>user: mostrar banner rojo Sin conexión
    end

    %% Cierre de sesión (CA-4)
    user->>login: presionar Cerrar sesión
    login->>cubit: AuthCubit.logout()
    cubit->>ds: POST /api/auth/logout
    ds->>nginx: HTTPS
    nginx->>be_login: proxy_pass /api/auth/logout
    be_login->>db: DELETE FROM refresh_token WHERE token = :token
    be_login-->>ds: 204 No Content
    cubit->>ss: eliminar access_token + refresh_token
    cubit-->>login: AuthState.unauthenticated
    login->>user: navegar a LoginPage

    Note right of ss: El dispositivo NUNCA almacena password_hash en texto plano
