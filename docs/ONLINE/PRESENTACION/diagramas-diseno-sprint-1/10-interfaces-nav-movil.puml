' ============================================================
' SECCIÓN DEL DOCUMENTO: § 8. R-3 — Ejecución del Sprint 1 › § 8.2 Diseño de Interfaces — Flujo de Navegación App Móvil
' Archivo: docs/ONLINE/PRESENTACION/presentacion-scrum-s0-s1.md
' Perspectiva de diseño: (d) Diseño de Interfaces — App Móvil Flutter (Sprint 1)
' ============================================================

@startuml
title Diseño de Interfaces — Flujo de Navegación App Móvil (Sprint 1)\nWireless HeatMapper — Flutter / go_router (modalidad 100 % en línea)
skinparam activityBackgroundColor #EBF5FB
skinparam activityBorderColor #2980B9
skinparam arrowColor #2980B9
skinparam noteBackgroundColor #FFFDE7
skinparam activityDiamondBackgroundColor #FFFDE7
skinparam activityDiamondBorderColor #2980B9

start

' ─── Splash ──────────────────────────────────────────────────
:SplashPage
· logo + indicador de carga
· lee tokens de SecureStorage
· intenta POST /api/auth/refresh;
note right
  Ruta: / (SplashPage)
  Duración: ≤ 2 s
  Íconos: logo Wireless HeatMapper
end note

if (¿refresh_token válido?) then (sí — 200)
  :ProyectosPage
  · AppBar con nombre del técnico + botón logout
  · Tabs: "Activos" / "Archivados"
  · SearchBar en tiempo real
  · ListView de tarjetas de proyecto
  · FAB "+ Nuevo";
  note right
    Ruta: /proyectos
    HU: PB-10 (listar) + PB-01 (crear/archivar)
    GET /api/proyectos (automático)
  end note
else (no / sin conexión / token expirado)
  :LoginPage
  · Card centrada con logo
  · Campo email + contraseña
  · Botón "Iniciar sesión"
  · Banner rojo "Sin conexión" (si offline)
  · Botón deshabilitado si sin red;
  note right
    Ruta: /login
    HU: PB-09
    POST /api/auth/login
  end note

  if (credenciales válidas?) then (sí — 200)
    :guardar tokens en SecureStorage;
    :ProyectosPage;
  else (401/403 / sin conexión)
    :mostrar mensaje de error inline\no banner sin conexión;
    stop
  endif
endif

' ─── Desde ProyectosPage ─────────────────────────────────────
if (acción del técnico) then (FAB: crear nuevo proyecto)
  :ProyectoFormPage — Crear
  · AppBar "Nuevo proyecto"
  · Campo "Nombre" (requerido)
  · DropdownSearch "Cliente" (activos de GET /api/clientes)
  · Campo "Descripción" (opcional)
  · Botón "Guardar" / "Cancelar";
  note right
    Ruta: /proyectos/nuevo
    HU: PB-01 CA-1
    POST /api/proyectos
  end note
  :volver a ProyectosPage (lista actualizada);
elseif (tap en proyecto) then (editar)
  :ProyectoFormPage — Editar
  · AppBar "Editar proyecto"
  · Datos precargados
  · Mismos campos que Crear
  · Botón "Guardar cambios";
  note right
    Ruta: /proyectos/{id}/editar
    HU: PB-01 CA-2
    PUT /api/proyectos/{id}
  end note
  :volver a ProyectosPage (lista actualizada);
elseif (menú contextual) then (archivar)
  :diálogo confirmación "¿Archivar proyecto?";
  :PATCH /api/proyectos/{id}/archivar;
  :proyecto desaparece del tab "Activos";
elseif (menú contextual) then (eliminar)
  :diálogo modal "¿Eliminar proyecto?\nEsta acción no se puede deshacer.";
  :DELETE /api/proyectos/{id};
  :proyecto eliminado de la lista;
else (logout)
  :POST /api/auth/logout;
  :limpiar SecureStorage (borrar tokens);
  :LoginPage;
  stop
endif

:ProyectosPage;

note right
  Material 3 · Tema claro y oscuro
  Tokens: AppPalette · AppSpacing · AppRadius
  Tipografía: Poppins (títulos) + Inter (cuerpo)
  Colores primarios: azul #2980B9 · fondo #EBF5FB
  Banner error: rojo · Banner sin conexión: ámbar
end note

stop
@enduml
