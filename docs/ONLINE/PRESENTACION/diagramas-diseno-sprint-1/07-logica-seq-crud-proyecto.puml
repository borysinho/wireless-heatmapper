' ============================================================
' SECCIÓN DEL DOCUMENTO: § 8. R-3 — Ejecución del Sprint 1 › Diseño de Lógica — PB-01 / PB-10 CRUD Proyecto
' Archivo: docs/ONLINE/PRESENTACION/presentacion-scrum-s0-s1.md
' Perspectiva de diseño: (c) Diseño de Lógica — HU: PB-01 Gestionar Proyecto + PB-10 Ver Historial
' ============================================================

@startuml
title Diseño de Lógica — Diagrama de Secuencia\nPB-01: Gestionar Proyecto de Survey (CRUD Móvil)\nPB-10: Ver Historial de Proyectos\nWireless HeatMapper (modalidad 100 % en línea)
skinparam sequenceArrowColor #2980B9
skinparam participantBackgroundColor #EBF5FB
skinparam participantBorderColor #2980B9
skinparam sequenceLifeLineBorderColor #2980B9
skinparam noteBackgroundColor #FFFDE7
skinparam sequenceGroupBackgroundColor #F0F8FF
skinparam sequenceGroupBorderColor #2980B9

actor "Técnico\nautenticado" as user
participant "ProyectosPage\n(Flutter)" as page
participant "ProyectosCubit\n(BLoC)" as cubit
participant "ProyectoRemoteDataSource\n(Dio + AuthInterceptor)" as ds
participant "Nginx" as nginx
participant "GET|POST|PUT|PATCH|DELETE\n/api/proyectos\n(FastAPI — ProyectoRepository)" as be
database "PostgreSQL\n(tabla proyecto)" as db

' ─── PB-10: Listar proyectos ─────────────────────────────────
== PB-10 — Ver listado de proyectos (CA-1) ==
user -> page : abre ProyectosPage
page -> cubit : ProyectosCubit.cargar()
cubit -> ds : GET /api/proyectos\nAuthorization: Bearer <access_token>
ds -> nginx : HTTPS
nginx -> be : proxy_pass (AuthInterceptor valida JWT)
be -> db : SELECT * FROM proyecto\nWHERE tecnico_id = :user_id\nAND estado != 'archivado'\nORDER BY ultima_actividad DESC
db --> be : lista de proyectos
be --> ds : 200 [ProyectoTecnicoOut, ...]
cubit --> page : ProyectosState.loaded(proyectos)
page -> user : mostrar lista con nombre, cliente,\nestado, última actividad

group sin proyectos aún [CA vacío]
  be --> ds : 200 []
  cubit --> page : ProyectosState.empty
  page -> user : mostrar estado vacío\n"Aún no tienes proyectos. Toca + para crear uno."
end

note right of be
  El backend filtra automáticamente
  por tecnico_id del token JWT.
  Un técnico NUNCA puede ver proyectos
  de otro técnico (PB-01 CA5).
end note

' ─── PB-01: Crear proyecto ───────────────────────────────────
== PB-01 — Crear proyecto nuevo (CA-1) ==
user -> page : presiona FAB "+ Nuevo"
page -> user : navegar a ProyectoFormPage (formulario vacío)
user -> page : completa nombre, selecciona cliente,\nescribe descripción (opcional)
page -> cubit : ProyectosCubit.crear(nombre, clienteId, descripcion)
cubit -> ds : POST /api/proyectos\n{nombre, cliente_id, descripcion}
ds -> nginx : HTTPS
nginx -> be : proxy_pass
be -> db : INSERT INTO proyecto\n(nombre, tecnico_id, cliente_id, descripcion, estado='nuevo')
db --> be : nuevo registro
be --> ds : 201 {ProyectoTecnicoOut}
cubit --> page : ProyectosState.created
page -> user : volver a lista; proyecto aparece en la cabecera

' ─── PB-01: Editar proyecto ──────────────────────────────────
== PB-01 — Editar proyecto (CA-2) ==
user -> page : toca proyecto → "Editar"
page -> user : navegar a ProyectoFormPage (datos precargados)
user -> page : modifica nombre / cliente / descripción
page -> cubit : ProyectosCubit.editar(id, nombre, clienteId, descripcion)
cubit -> ds : PUT /api/proyectos/{id}\n{nombre, cliente_id, descripcion}
ds -> nginx : HTTPS
nginx -> be : proxy_pass
be -> db : SELECT proyecto WHERE id=:id AND tecnico_id=:user_id
group proyecto encontrado
  be -> db : UPDATE proyecto SET nombre=..., cliente_id=...,\ndescripcion=..., ultima_actividad=now()
  db --> be : proyecto actualizado
  be --> ds : 200 {ProyectoTecnicoOut}
  cubit --> page : ProyectosState.updated
  page -> user : lista actualizada
end
group proyecto de otro técnico
  db --> be : NULL
  be --> ds : 404 {detail: "Proyecto no encontrado."}
  cubit --> page : ProyectosState.error
end

' ─── PB-01: Archivar proyecto ────────────────────────────────
== PB-01 — Archivar proyecto (CA-3) ==
user -> page : toca menú contextual → "Archivar"
page -> cubit : ProyectosCubit.archivar(id)
cubit -> ds : PATCH /api/proyectos/{id}/archivar
ds -> nginx : HTTPS
nginx -> be : proxy_pass
be -> db : UPDATE proyecto SET estado='archivado'\nWHERE id=:id AND tecnico_id=:user_id
db --> be : proyecto actualizado
be --> ds : 200 {ProyectoTecnicoOut estado=archivado}
cubit --> page : ProyectosState.archived
page -> user : proyecto desaparece del listado principal

note right of be
  Para ver archivados el técnico usa
  GET /api/proyectos?estado=archivado
  (filtro por estado en query param).
end note

' ─── PB-01: Eliminar proyecto ────────────────────────────────
== PB-01 — Eliminar proyecto (CA-4) ==
user -> page : toca menú contextual → "Eliminar"
page -> user : mostrar diálogo de confirmación modal
user -> page : confirma eliminación
page -> cubit : ProyectosCubit.eliminar(id)
cubit -> ds : DELETE /api/proyectos/{id}
ds -> nginx : HTTPS
nginx -> be : proxy_pass
be -> db : DELETE FROM proyecto WHERE id=:id AND tecnico_id=:user_id
db --> be : fila eliminada
be --> ds : 204 No Content
cubit --> page : ProyectosState.deleted
page -> user : proyecto desaparece de la lista
@enduml
