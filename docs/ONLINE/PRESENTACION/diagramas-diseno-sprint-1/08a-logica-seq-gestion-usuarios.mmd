%% PB-13: Gestionar Usuarios (Panel Admin Web)
%% Wireless HeatMapper — modalidad 100% en línea
%% Compatibilidad StarUML: solo ->> y -->>, sin box/rect/link/estilos

sequenceDiagram
    actor admin as Administrador
    participant web as GestionUsuarios.tsx
    participant axios as axiosClient
    participant nginx as Nginx
    participant be as API admin-usuarios
    participant db as PostgreSQL usuario

    %% Listar usuarios
    admin->>web: accede a /admin/usuarios
    web->>axios: GET /api/admin/usuarios Bearer token
    axios->>nginx: HTTPS
    nginx->>be: proxy_pass require_admin valida rolADMIN
    be->>db: SELECT * FROM usuario ORDER BY created_at DESC
    db-->>be: lista de usuarios
    be-->>axios: 200 lista UsuarioOut
    axios-->>web: datos usuarios
    web->>admin: tabla con nombre, email, rol, estado

    opt CA-4 tecnico intenta acceder
        be->>be: require_admin detecta rol=TECNICO
        be-->>axios: 403 No autorizado
        axios-->>web: error 403
        web->>admin: redirect a /admin/login
    end

    %% Crear técnico nuevo (CA-1)
    admin->>web: abre modal Nuevo tecnico
    admin->>web: completa nombre, email, contrasena, rol=TECNICO
    web->>axios: POST /api/admin/usuarios
    axios->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: SELECT usuario WHERE email=:email
    alt email disponible
        be->>be: bcrypt.hashpw(password, salt)
        be->>db: INSERT INTO usuario nombre, email, password_hash, rol, activo=TRUE
        db-->>be: nuevo registro
        be-->>axios: 201 UsuarioOut
        axios-->>web: datos usuario creado
        web->>admin: nuevo tecnico aparece ACTIVO
    else CA-3 email duplicado
        db-->>be: UNIQUE constraint violation
        be-->>axios: 409 El email ya esta registrado
        axios-->>web: error 409
        web->>admin: error Email ya registrado
    end

    %% Desactivar usuario (CA-2)
    admin->>web: toggle activo OFF en fila del tecnico
    web->>axios: PATCH /api/admin/usuarios/:id activo=false
    axios->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: UPDATE usuario SET activo=FALSE WHERE id=:id
    db-->>be: actualizado
    be-->>axios: 200 UsuarioOut activo=false
    axios-->>web: datos usuario actualizado
    web->>admin: badge cambia a INACTIVO

    Note right of be: Tecnico desactivado recibe 403 en siguiente request. Refresh tokens son rechazados
