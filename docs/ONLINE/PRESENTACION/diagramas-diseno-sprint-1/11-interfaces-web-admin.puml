package "GestionUsuarios.tsx (PB-13 вҖ” ruta /admin/usuarios)" as P_USR {
  component "Tabla de usuarios\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nВ· Columnas: Nombre В· Email В· Rol В· Estado В· Acciones\nВ· Badge ACTIVO (verde) / INACTIVO (rojo)\nВ· Toggle activo/inactivo con confirmaciГіn\nВ· BГәsqueda por nombre o email\nВ· PaginaciГіn (20 Гӯtems/pГЎgina)" as C_USR_TABLE

