%% PB-13: Gestionar Usuarios (Panel Admin Web)
%% PB-19: Gestionar Clientes (Panel Admin Web)
%% Wireless HeatMapper — modalidad 100% en línea
%% Compatibilidad StarUML: solo ->> y -->>, sin box/rect/link/estilos

sequenceDiagram
    actor admin as Administrador
    participant web_u as GestionUsuarios.tsx
    participant web_c as GestionClientes.tsx
    participant axios as axiosClient TanStack
    participant nginx as Nginx
    participant be_u as API admin-usuarios
    participant be_c as API admin-clientes
    participant db_u as PostgreSQL usuario
    participant db_c as PostgreSQL cliente

    %% PB-13: Listar usuarios
    admin->>web_u: accede a /admin/usuarios
    web_u->>axios: GET /api/admin/usuarios Bearer admin token
    axios->>nginx: HTTPS
    nginx->>be_u: proxy_pass - require_admin valida rol=ADMIN
    be_u->>db_u: SELECT * FROM usuario ORDER BY created_at DESC
    db_u-->>be_u: lista de usuarios
    be_u-->>axios: 200 lista UsuarioOut
    web_u->>admin: tabla con nombre, email, rol, estado

    opt CA-4: técnico intenta acceder
        be_u->>be_u: require_admin detecta rol=TECNICO
        be_u-->>axios: 403 No autorizado
        web_u->>admin: redirect a /admin/login
    end

    %% PB-13: Crear técnico nuevo (CA-1)
    admin->>web_u: abre modal Nuevo técnico
    admin->>web_u: completa nombre, email, contraseña, rol=TECNICO
    web_u->>axios: POST /api/admin/usuarios
    axios->>nginx: HTTPS
    nginx->>be_u: proxy_pass
    be_u->>db_u: SELECT usuario WHERE email=:email
    alt email disponible
        be_u->>be_u: bcrypt.hashpw(password, salt)
        be_u->>db_u: INSERT INTO usuario nombre, email, password_hash, rol, activo=TRUE
        db_u-->>be_u: nuevo registro
        be_u-->>axios: 201 UsuarioOut
        web_u->>admin: nuevo técnico aparece ACTIVO
    else CA-3: email duplicado
        db_u-->>be_u: UNIQUE constraint violation
        be_u-->>axios: 409 El email ya está registrado
        web_u->>admin: error Email ya registrado
    end

    %% PB-13: Desactivar usuario (CA-2)
    admin->>web_u: toggle activo OFF en fila del técnico
    web_u->>axios: PATCH /api/admin/usuarios/:id activo=false
    axios->>nginx: HTTPS
    nginx->>be_u: proxy_pass
    be_u->>db_u: UPDATE usuario SET activo=FALSE WHERE id=:id
    db_u-->>be_u: actualizado
    be_u-->>axios: 200 UsuarioOut activo=false
    web_u->>admin: badge cambia a INACTIVO

    Note right of be_u: Técnico desactivado recibe 403 en el siguiente request. Refresh tokens permanecen en BD pero son rechazados

    %% PB-19: Listar clientes
    admin->>web_c: accede a /admin/clientes
    web_c->>axios: GET /api/clientes Bearer token
    axios->>nginx: HTTPS
    nginx->>be_c: proxy_pass - cualquier usuario autenticado
    be_c->>db_c: SELECT * FROM cliente ORDER BY nombre
    db_c-->>be_c: lista completa
    be_c-->>axios: 200 lista ClienteOut
    web_c->>admin: tabla con nombre y badge activo/inactivo

    %% PB-19: Crear cliente (CA-1)
    admin->>web_c: abre modal Nuevo cliente
    admin->>web_c: ingresa nombre del cliente
    web_c->>axios: POST /api/admin/clientes
    axios->>nginx: HTTPS
    nginx->>be_c: proxy_pass - require_admin
    be_c->>db_c: SELECT cliente WHERE nombre=:nombre
    alt nombre disponible
        be_c->>db_c: INSERT INTO cliente nombre, activo=TRUE
        db_c-->>be_c: nuevo registro
        be_c-->>axios: 201 ClienteOut activo=true
        web_c->>admin: cliente aparece ACTIVO
    else CA-2: nombre duplicado
        be_c-->>axios: 409 El nombre del cliente ya existe
        web_c->>admin: error Nombre duplicado
    end

    %% PB-19: Desactivar cliente (CA-4)
    admin->>web_c: toggle activo OFF en fila del cliente
    web_c->>axios: PATCH /api/admin/clientes/:id activo=false
    axios->>nginx: HTTPS
    nginx->>be_c: proxy_pass
    be_c->>db_c: UPDATE cliente SET activo=FALSE WHERE id=:id
    db_c-->>be_c: actualizado
    be_c-->>axios: 200 ClienteOut activo=false
    web_c->>admin: badge cambia a INACTIVO

    Note right of be_c: El selector de proyectos solo muestra clientes activos. Proyectos históricos conservan la FK via LEFT JOIN
