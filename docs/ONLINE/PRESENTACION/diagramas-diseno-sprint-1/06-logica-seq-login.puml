' ============================================================
' SECCIÓN DEL DOCUMENTO: § 8. R-3 — Ejecución del Sprint 1 › § 8.1 Diagrama de secuencia — Login extremo a extremo
' Archivo: docs/ONLINE/PRESENTACION/presentacion-scrum-s0-s1.md
' Perspectiva de diseño: (c) Diseño de Lógica — HU: PB-09 Autenticar Usuario (móvil)
' ============================================================

@startuml
title Diseño de Lógica — Diagrama de Secuencia\nPB-09: Autenticar Usuario (Login y Refresh Token)\nWireless HeatMapper (modalidad 100 % en línea)
skinparam sequenceArrowColor #2980B9
skinparam participantBackgroundColor #EBF5FB
skinparam participantBorderColor #2980B9
skinparam sequenceLifeLineBorderColor #2980B9
skinparam noteBackgroundColor #FFFDE7
skinparam sequenceGroupBackgroundColor #F0F8FF
skinparam sequenceGroupBorderColor #2980B9

actor "Técnico" as user
participant "SplashPage\n(Flutter)" as splash
participant "LoginPage\n(Flutter)" as login
participant "AuthCubit\n(BLoC)" as cubit
participant "AuthRemoteDataSource\n(Dio)" as ds
participant "Nginx\n(reverse proxy)" as nginx
participant "POST /api/auth/login\n(FastAPI — AuthService)" as be_login
participant "POST /api/auth/refresh\n(FastAPI — AuthService)" as be_refresh
database "PostgreSQL\n(tabla usuario)" as db
participant "SecureStorage\n(flutter_secure_storage)" as ss

' ─── Arranque: verificación de sesión previa ─────────────────
== Arranque de la app ==
splash -> ss : leer access_token + refresh_token
alt tokens presentes → intentar renovar sesión
  splash -> ds : POST /api/auth/refresh\n{refresh_token}
  ds -> nginx : HTTPS
  nginx -> be_refresh : proxy_pass
  be_refresh -> db : SELECT refresh_token WHERE token=... AND expires_at > now()
  db --> be_refresh : registro encontrado
  be_refresh --> splash : 200 {access_token nuevo}
  splash -> ss : guardar nuevo access_token
  splash -> user : navegar a ProyectosPage (sin pasar por Login)
else no hay tokens o refresh expirado
  splash -> user : navegar a LoginPage
end

' ─── Flujo principal: Login con credenciales ─────────────────
== Login con credenciales ==
user -> login : ingresa email + contraseña
login -> cubit : AuthCubit.login(email, password)
cubit -> ds : POST /api/auth/login\n{email, password}
ds -> nginx : HTTPS :443
nginx -> be_login : proxy_pass :8000 /api/auth/login

be_login -> db : SELECT * FROM usuario WHERE email = :email
db --> be_login : fila usuario (o vacío)

group credenciales válidas y cuenta activa [CA-1]
  be_login -> be_login : bcrypt.checkpw(password, password_hash)
  be_login -> be_login : generar access_token (exp: 15 min)\ngenerar refresh_token (exp: 7 días)
  be_login -> db : INSERT INTO refresh_token (token, usuario_id, expires_at)
  be_login -> db : UPDATE usuario SET ultimo_acceso = now()
  be_login --> ds : 200 {access_token, refresh_token,\nusuario:{id,nombre,email,rol}}
  ds --> cubit : TokenResponse
  cubit -> ss : guardar access_token + refresh_token\n(flutter_secure_storage — cifrado AES)
  cubit --> login : AuthState.authenticated
  login -> user : navegar a ProyectosPage
end

group credenciales inválidas [CA-2]
  be_login --> ds : 401 {detail: "Credenciales inválidas"}
  ds --> cubit : DioException (401)
  cubit --> login : AuthState.error("Credenciales inválidas")
  login -> user : mostrar mensaje de error (sin indicar qué campo)
end

group cuenta desactivada [CA-3]
  be_login --> ds : 403 {detail: "Cuenta desactivada. Contacte al administrador"}
  ds --> cubit : DioException (403)
  cubit --> login : AuthState.error("Cuenta desactivada...")
  login -> user : mostrar mensaje específico
end

group sin conexión al backend [CA-5]
  ds -> nginx : timeout / no route
  ds --> cubit : DioException (tipo: ConnectionError)
  cubit --> login : AuthState.sinConexion
  login -> user : mostrar banner rojo "Sin conexión"\ndeshabilitar botón de inicio de sesión
end

' ─── Cierre de sesión ────────────────────────────────────────
== Cierre de sesión (CA-4) ==
user -> login : presionar "Cerrar sesión"
login -> cubit : AuthCubit.logout()
cubit -> ds : POST /api/auth/logout {refresh_token}
ds -> nginx : HTTPS
nginx -> be_login : proxy_pass /api/auth/logout
be_login -> db : DELETE FROM refresh_token WHERE token = :token
be_login --> ds : 204 No Content
cubit -> ss : eliminar access_token + refresh_token
cubit --> login : AuthState.unauthenticated
login -> user : navegar a LoginPage

note right of ss
  CA-6: el dispositivo NUNCA almacena
  password_hash ni email en texto plano.
  Solo los tokens JWT residen en
  SecureStorage (cifrado AES).
end note
@enduml
