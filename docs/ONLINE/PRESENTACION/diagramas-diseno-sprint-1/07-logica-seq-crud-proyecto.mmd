%% PB-01: Gestionar Proyecto de Survey (CRUD Móvil)
%% PB-10: Ver Historial de Proyectos
%% Wireless HeatMapper — modalidad 100% en línea
%% Compatibilidad StarUML: solo ->> y -->>, sin box/rect/link/estilos

sequenceDiagram
    actor user as Técnico autenticado
    participant page as ProyectosPage
    participant cubit as ProyectosCubit
    participant ds as ProyectoRemoteDS
    participant nginx as Nginx
    participant be as API proyectos
    participant db as PostgreSQL

    %% PB-10: Listar proyectos (CA-1)
    user->>page: abre ProyectosPage
    page->>cubit: ProyectosCubit.cargar()
    cubit->>ds: GET /api/proyectos Bearer token
    ds->>nginx: HTTPS
    nginx->>be: proxy_pass - AuthInterceptor valida JWT
    be->>db: SELECT proyectos WHERE tecnico_id = :user_id ORDER BY ultima_actividad DESC
    db-->>be: lista de proyectos
    be-->>ds: 200 lista ProyectoTecnicoOut
    cubit-->>page: ProyectosState.loaded
    page->>user: lista con nombre, cliente, estado, última actividad

    opt sin proyectos aún
        be-->>ds: 200 lista vacía
        cubit-->>page: ProyectosState.empty
        page->>user: estado vacío - Toca + para crear uno
    end

    Note right of be: El backend filtra por tecnico_id del JWT. Un técnico NUNCA ve proyectos de otro técnico

    %% PB-01: Crear proyecto (CA-1)
    user->>page: presiona FAB Nuevo
    page->>user: navegar a ProyectoFormPage vacío
    user->>page: completa nombre, selecciona cliente, descripción
    page->>cubit: ProyectosCubit.crear(nombre, clienteId, descripcion)
    cubit->>ds: POST /api/proyectos
    ds->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: INSERT INTO proyecto nombre, tecnico_id, cliente_id, estado=nuevo
    db-->>be: nuevo registro
    be-->>ds: 201 ProyectoTecnicoOut
    cubit-->>page: ProyectosState.created
    page->>user: volver a lista con proyecto en cabecera

    %% PB-01: Editar proyecto (CA-2)
    user->>page: toca proyecto - Editar
    page->>user: navegar a ProyectoFormPage con datos precargados
    user->>page: modifica nombre, cliente o descripción
    page->>cubit: ProyectosCubit.editar(id, nombre, clienteId, descripcion)
    cubit->>ds: PUT /api/proyectos/:id
    ds->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: SELECT proyecto WHERE id=:id AND tecnico_id=:user_id
    alt proyecto encontrado
        be->>db: UPDATE proyecto SET nombre, cliente_id, ultima_actividad=now()
        db-->>be: proyecto actualizado
        be-->>ds: 200 ProyectoTecnicoOut
        cubit-->>page: ProyectosState.updated
        page->>user: lista actualizada
    else proyecto de otro técnico
        db-->>be: sin resultado
        be-->>ds: 404 Proyecto no encontrado
        cubit-->>page: ProyectosState.error
    end

    %% PB-01: Archivar proyecto (CA-3)
    user->>page: menú contextual - Archivar
    page->>cubit: ProyectosCubit.archivar(id)
    cubit->>ds: PATCH /api/proyectos/:id/archivar
    ds->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: UPDATE proyecto SET estado=archivado WHERE id=:id AND tecnico_id=:user_id
    db-->>be: proyecto actualizado
    be-->>ds: 200 ProyectoTecnicoOut estado=archivado
    cubit-->>page: ProyectosState.archived
    page->>user: proyecto desaparece del listado principal

    Note right of be: Para ver archivados usar GET /api/proyectos?estado=archivado

    %% PB-01: Eliminar proyecto (CA-4)
    user->>page: menú contextual - Eliminar
    page->>user: mostrar diálogo de confirmación
    user->>page: confirma eliminación
    page->>cubit: ProyectosCubit.eliminar(id)
    cubit->>ds: DELETE /api/proyectos/:id
    ds->>nginx: HTTPS
    nginx->>be: proxy_pass
    be->>db: DELETE FROM proyecto WHERE id=:id AND tecnico_id=:user_id
    db-->>be: fila eliminada
    be-->>ds: 204 No Content
    ds-->>cubit: operacion completada
    cubit-->>page: ProyectosState.deleted
    page->>user: proyecto desaparece de la lista
