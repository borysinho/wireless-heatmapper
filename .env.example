# ─────────────────────────────────────────
# Wireless HeatMapper — Variables de entorno de referencia
# Copiar a .env y completar con valores reales (nunca commitear .env)
# ─────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=heatmapper
POSTGRES_USER=heatmapper_user
POSTGRES_PASSWORD=cambia_esto_en_produccion

# Backend FastAPI
DATABASE_URL=postgresql://heatmapper_user:cambia_esto_en_produccion@db:5432/heatmapper
SECRET_KEY=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Firebase Admin (notificaciones de asignación)
FIREBASE_PROJECT_ID=heatmapper-940e6
# Docker Compose monta .secrets/firebase-admin.json como archivo de solo lectura.
# El directorio .secrets está excluido de Git y nunca debe versionarse.

# Correo transaccional (cuentas creadas y enlaces de cliente)
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=correo@gmail.com
SMTP_PASSWORD=contraseña_de_aplicacion
SMTP_FROM_EMAIL=correo@gmail.com
SMTP_FROM_NAME=Wireless HeatMapper
PUBLIC_WEB_URL=http://localhost

# Storage de planos (Sprint 2)
STORAGE_ROOT=/var/lib/heatmapper/planos
STORAGE_URL_SECRET=cambia_esto_secreto_para_firmar_urls_minimo_32_chars
STORAGE_URL_TTL_SECONDS=3600

# Web React (Vite)
VITE_API_BASE_URL=http://localhost/api
